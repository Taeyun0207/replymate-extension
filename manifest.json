{
  "manifest_version": 3,
  "name": "ReplyMate",
  "version": "1.0",
  "description": "AI powered Gmail reply assistant",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"]
    }
  ],
  "action": {
    "default_title": "ReplyMate",
    "default_popup": "popup/popup.html"
  }
}

