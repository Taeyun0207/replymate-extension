{
  "manifest_version": 3,
  "name": "ReplyMate",
  "version": "1.0.0",
  "description": "AI-powered Gmail reply assistant",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://replymate-backend-bot8.onrender.com/*"
  ], 
  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"]
    }
  ],

  "action": {
    "default_title": "ReplyMate",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}