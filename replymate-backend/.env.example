# Copy to .env for local dev. On Render: Dashboard → your Web Service → Environment.

# --- Required (see SUPABASE_SETUP.md) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# or SUPABASE_ANON_KEY for limited operations
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (subscription + optional top-ups)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PRO_PLUS_MONTHLY=
STRIPE_PRICE_PRO_PLUS_ANNUAL=
# STRIPE_PRICE_TOPUP_100=
# STRIPE_PRICE_TOPUP_500=

# --- Optional: billing return URLs (pricing page) ---
# If OMITTED, server.js defaults are used — you do NOT need these on Render unless overriding.
# Defaults: https://replymateai.app/pricing?success=1 and ...?cancelled=1
# BILLING_SUCCESS_URL=https://replymateai.app/pricing?success=1
# BILLING_CANCEL_URL=https://replymateai.app/pricing?cancelled=1

# --- Optional ---
# PORT=3000
# OPENAI_MODEL=gpt-4o-mini
# TRANSLATION_MODEL=
# DB_TABLE_NAME=users
