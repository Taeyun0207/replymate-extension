{
  "manifest_version": 3,
  "name": "ReplyMate: AI Email Reply Assistant & Translator",
  "version": "1.0.4",
  "description": "AI-powered Gmail & Outlook reply assistant",
  "permissions": [
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "292807400870-2rp43fmhiojff39999jpu2mf4pahfr06.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://replymate-backend-bot8.onrender.com/*",
    "https://*.supabase.co/*",
    "https://accounts.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "lib/auth-config.js",
        "lib/auth-shared.js",
        "content/gmail.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*"
      ],
      "js": [
        "lib/auth-config.js",
        "lib/auth-shared.js",
        "content/outlook.js",
        "content/translation-common.js",
        "content/translation.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://replymateai.app/*",
        "*://taeyun0207.github.io/replymate-site/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": [
        "content/auth-sync-website.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/auth-config.js",
        "lib/auth-shared.js",
        "content/translation-common.js",
        "content/translation.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ReplyMate",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}